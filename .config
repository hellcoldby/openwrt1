#
# OpenWrt Configuration for BCM96328AVNG (BCM4313 WiFi Fix)
# Target: bcm63xx / smp (BCM6328 SMP)
# Kernel: 5.10.x (OpenWrt 22.03.x)
# Generated for cloud build with BCM4313 LCN SPROM fix
#

CONFIG_TARGET_bcm63xx=y
CONFIG_TARGET_bcm63xx_smp=y
CONFIG_TARGET_bcm63xx_smp_DEVICE_tianbei-rg100a-ba=y

#
# General Setup
#
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_OVERLAYFS=y

#
# Kernel Modules
#

## BCMA Bus Support (required for brcmsmac)
CONFIG_PACKAGE_kmod-bcma=y

## Broadcom Wireless Driver - brcmsmac (FullMAC, only option for LCN PHY)
CONFIG_PACKAGE_kmod-brcmsmac=y

## Required dependencies for brcmsmac
CONFIG_PACKAGE_kmod-brcmutil=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-lib-crc-ccitt=y

## Crypto modules required by mac80211
CONFIG_PACKAGE_kmod-crypto-aead=y
CONFIG_PACKAGE_kmod-crypto-ccm=y
CONFIG_PACKAGE_kmod-crypto-gcm=y
CONFIG_PACKAGE_kmod-crypto-pcompress=y
CONFIG_PACKAGE_kmod-crypto-hash=y
CONFIG_PACKAGE_kmod-crypto-manager=y
CONFIG_PACKAGE_kmod-crypto-ecb=y
CONFIG_PACKAGE_kmod-crypto-arc4=y
CONFIG_PACKAGE_kmod-crypto-deflate=y
CONFIG_PACKAGE_kmod-crypto-cmac=y
CONFIG_PACKAGE_kmod-crypto-sha256=y
CONFIG_PACKAGE_kmod-crypto-sha512=y

## LED/RFKill support
CONFIG_PACKAGE_kmod-leds-gpio=y
CONFIG_PACKAGE_kmod-input-core=y
CONFIG_PACKAGE_kmod-rfkill=y

## USB support (optional but useful)
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-nls-base=y

## File systems
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y

## Network support
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-nf-reject=y

#
# Packages
#

## WiFi AP daemon
CONFIG_PACKAGE_wpad-basic-wolfssl=y

## Web Management Interface
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y

## LuCI Web Framework (required for web UI)
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-proto-ppp=y
CONFIG_PACKAGE_luci-proto-ipv6=y

## Network utilities
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_dnsmasq_full=y
CONFIG_PACKAGE_dropbear=y

## System utilities
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_udev=y
CONFIG_PACKAGE_jshn=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_libubus=y
CONFIG_PACKAGE_libubox=y
CONFIG_PACKAGE_libjson-c=y
CONFIG_PACKAGE_libblobmsg-json=y
CONFIG_PACKAGE_libiwinfo=y
CONFIG_PACKAGE_libiwinfo-data=y

## Debug tools (for diagnostics)
CONFIG_PACKAGE_strace=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_pciutils=y

#
# Image Builder Options
#
CONFIG_BINARY_FOLDER="./bin/targets/bcm63xx/smp"
CONFIG_BUILD_DIR="$(TOPDIR)/build"
CONFIG_DOWNLOAD_FOLDER="$(TOPDIR)/dl"
CONFIG_INCLUDE_CONFIG=y
CONFIG_KERNEL_DEBUG_INFO=n
CONFIG_KERNEL_DEBUG_KERNEL=n
CONFIG_USE_STRIP=y
CONFIG_USE_SSTRIP=y
